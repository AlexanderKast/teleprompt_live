# ============================================================
#  FakeLive Pro — Variables de entorno
#  Copia este archivo como .env y llena los valores reales
#  NUNCA subas .env a GitHub (ya está en .gitignore)
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Encuentra estos valores en: Supabase Dashboard → Settings → API

# URL del proyecto (pública — se puede ver en auth.js)
SUPABASE_URL=https://ydpnzcspwlwfcxzizqct.supabase.co

# Anon Key (pública — se puede ver en auth.js)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (SECRETA — solo para el servidor, NUNCA en el frontend)
# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Gemini / Google AI ────────────────────────────────────────
# Cada usuario ingresa SU propia clave desde la app (Settings → API Key)
# Esta variable es OPCIONAL — solo si quieres usar el servidor para generar avatares
# Google AI Studio → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# ── Servidor local ────────────────────────────────────────────
PORT=3000
